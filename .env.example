# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/offwxwpbhxklatnqlbcc/settings/api
# Or if project doesn't exist, create new one at: https://supabase.com/dashboard

VITE_SUPABASE_URL=https://offwxwpbhxklatnqlbcc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# ============================================
# EDGE FUNCTION SECRETS
# ============================================
# IMPORTANT: Do NOT add API keys to this .env file!
# Set these via Supabase CLI instead:
# 
# npx supabase login
# npx supabase link --project-ref offwxwpbhxklatnqlbcc
# npx supabase secrets set OPENAI_API_KEY="sk-your-key-here"
# npx supabase secrets set FIRECRAWL_API_KEY="fc-your-key-here"

# ============================================
# API KEYS (Get These)
# ============================================
# OpenAI API Key: https://platform.openai.com/api-keys
# - Required for blog generation
# - Cost: ~$0.002-0.005 per blog post
# - Set via CLI: npx supabase secrets set OPENAI_API_KEY="sk-..."

# Firecrawl API Key: https://firecrawl.dev
# - Required for SEO competitor analysis
# - Free tier: 500 requests/month
# - Set via CLI: npx supabase secrets set FIRECRAWL_API_KEY="fc-..."

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
NODE_ENV=development

# ============================================
# OPTIONAL: WordPress Testing
# ============================================
# You can test WordPress integration after setting up via UI
# No environment variables needed - stored in Supabase profiles table
